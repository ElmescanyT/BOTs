@bot.tree.command(
    name="athena",
    description="Fale como a Athena."
)
@app_commands.describe(
    mensagem="Mensagem que a Athena vai enviar",
    canal="Canal onde a mensagem será enviada",
    imagem="Imagem para anexar à mensagem (opcional)"
)
async def athena(
    interaction: discord.Interaction,
    mensagem: str,
    canal: discord.TextChannel,
    imagem: discord.Attachment = None
):
    if not tem_cargo_permitido(interaction):
        await interaction.response.send_message(
            "❌ Você não possui o cargo necessário para usar este comando.",
            ephemeral=True
        )
        return

    await interaction.response.send_message("✅ Mensagem enviada!", ephemeral=True)

    embed = discord.Embed(
        description=mensagem,
        color=discord.Color.from_str("#7B68EE"),
        timestamp=datetime.utcnow()
    )
    embed.set_author(
        name="Athena",
        icon_url="https://cdn-icons-png.flaticon.com/512/4712/4712035.png"
    )

    if imagem:
        embed.set_image(url=imagem.url)

    await canal.send(embed=embed)

