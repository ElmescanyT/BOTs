@bot.command()
async def vincular(ctx, membro: discord.Member, username: str):
    if not has_dev_permission(ctx.author):
        embed = discord.Embed(description="❌ Você não tem permissão para usar este comando.", color=0xff0000)
        return await ctx.send(embed=embed)

    user_data = await get_roblox_data(username)
    if not user_data:
        embed = discord.Embed(description="❌ Nome de usuário Roblox inválido ou não encontrado.", color=0xff0000)
        return await ctx.send(embed=embed)

    roblox_id = user_data["id"]
    salvar_vinculo(membro.id, roblox_id)

    embed = discord.Embed(title="🔗 Vinculação Realizada com Sucesso", color=0x2ecc71)
    embed.set_thumbnail(url=f"https://www.roblox.com/headshot-thumbnail/image?userId={roblox_id}&width=150&height=150&format=png")
    embed.add_field(name="👤 Discord", value=f"{membro.mention} (`{membro.id}`)", inline=False)
    embed.add_field(name="🎮 Roblox", value=f"{username} (`{roblox_id}`)", inline=False)
    embed.add_field(name="🌐 Perfil", value=f"[Abrir perfil](https://www.roblox.com/users/{roblox_id}/profile)", inline=False)
    embed.set_footer(text=f"Solicitado por {ctx.author.display_name}", icon_url=ctx.author.avatar.url if ctx.author.avatar else None)
    await ctx.send(embed=embed)

@bot.command()
async def info_militar(ctx, membro: discord.Member):
    if not has_dev_permission(ctx.author):
        embed = discord.Embed(description="❌ Você não tem permissão para usar este comando.", color=0xff0000)
        return await ctx.send(embed=embed)

    embed_loading = discord.Embed(description="🔎 **Buscando informações... Aguarde.**", color=0xffd700)
    msg = await ctx.send(embed=embed_loading)

    try:
        discord_id = membro.id
        vinculos = carregar_json(VINCULOS_FILE)
        roblox_id = vinculos.get(str(discord_id))

        if not roblox_id:
            embed = discord.Embed(description="❌ Este membro não tem uma conta Roblox vinculada.", color=0xff0000)
            return await msg.edit(embed=embed)

        roblox_info = await get_user_data(roblox_id)
        if roblox_info is None:
            embed = discord.Embed(description="❌ Não foi possível obter os dados do Roblox. Verifique o ID ou a API do Roblox.", color=0xff0000)
            return await msg.edit(embed=embed)

        roblox_created_str = roblox_info.get("created", "Desconhecido")
        joined_roblox = "Desconhecido"
        if roblox_created_str != "Desconhecido":
            try:
                dt_object = datetime.fromisoformat(roblox_created_str.replace('Z', '+00:00'))
                joined_roblox = dt_object.strftime("%d/%m/%Y %H:%M")
            except ValueError:
                pass

        joined_discord = "Desconhecido"
        if membro.joined_at:
            joined_discord = membro.joined_at.strftime("%d/%m/%Y %H:%M")

        cargo_eb = await get_group_rank(roblox_id, GRUPO_EB)
        cargo_clea = await get_group_rank(roblox_id, GRUPO_CLEA)

        cargo_eb_display = f"**{cargo_eb}**" if cargo_eb else "❌ Não pertence ao grupo EB"
        cargo_clea_display = f"**{cargo_clea}**" if cargo_clea else "❌ Não pertence ao grupo CLEA"

        embed = discord.Embed(title="📋 Informações do Militar", color=0x3498db)
        embed.set_thumbnail(url=f"https://www.roblox.com/headshot-thumbnail/image?userId={roblox_id}&width=420&height=420&format=png")
        embed.add_field(name="👤 Membro Discord", value=f"{membro.mention} ({membro.name})", inline=False)
        embed.add_field(name="🆔 ID do Discord", value=f"`{discord_id}`", inline=False)
        embed.add_field(name="🎮 Nome de Usuário Roblox", value=roblox_info.get("name", "N/A"), inline=False)
        embed.add_field(name="🕹️ ID do Roblox", value=f"`{roblox_id}`", inline=False)
        embed.add_field(name="🌐 Perfil do Roblox", value=f"[Clique aqui](https://www.roblox.com/users/{roblox_id}/profile)", inline=False)
        embed.add_field(name="🎖️ Cargo no Exército Brasileiro", value=cargo_eb_display, inline=False)
        embed.add_field(name="🛡️ Cargo no CLEA", value=cargo_clea_display, inline=False)
        embed.add_field(name="🗓️ Entrou no Roblox", value=joined_roblox, inline=True)
        embed.add_field(name="📥 Entrou no Servidor", value=joined_discord, inline=True)
        embed.set_footer(text=f"Solicitado por {ctx.author.display_name}", icon_url=ctx.author.avatar.url if ctx.author.avatar else None)

        await msg.edit(embed=embed)

    except Exception:
        print("❌ ERRO no comando info_militar:")
        traceback.print_exc()
