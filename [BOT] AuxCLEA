class DeleteReasonModal(Modal, title="Motivo da Exclusão do Relatório"):
    reason = TextInput(
        label="Por que você está apagando este relatório?",
        style=discord.TextStyle.paragraph,
        placeholder="Ex: 'Dados incorretos', 'Relatório duplicado', 'Erro de registro'",
        required=True,
        max_length=500
    )

    def __init__(self, ctx, parent_view):
        super().__init__()
        self.ctx = ctx
        self.parent_view = parent_view

    async def on_submit(self, interaction: discord.Interaction):
        await interaction.response.defer(ephemeral=True) # Defer a resposta para ter tempo de processar
        relatorios_data = carregar_json(RELATORIOS_FILE)
        rel_id_to_delete = self.parent_view.selected_relatorio_id

        if rel_id_to_delete in relatorios_data:
            deleted_rel_info = relatorios_data.pop(rel_id_to_delete)
            salvar_json(RELATORIOS_FILE, relatorios_data)

            log_channel = self.ctx.guild.get_channel(CANAL_LOGS_EXCLUSAO_RELATORIOS)
            if log_channel:
                militar_name = await self.parent_view.get_member_name(deleted_rel_info.get("militar_id", "N/A"))
                instrutor_name = await self.parent_view.get_member_name(deleted_rel_info.get("instrutor_id", "N/A"))

                embed_log = discord.Embed(
                    title="🗑️ Relatório Apagado!",
                    description="Um relatório foi excluído do sistema.",
                    color=discord.Color.red()
                )
                embed_log.add_field(name="👤 Militar", value=militar_name, inline=True)
                embed_log.add_field(name="🧑‍🏫 Instrutor (No Relatório)", value=instrutor_name, inline=True)
                embed_log.add_field(name="📅 Dia do Relatório", value=deleted_rel_info.get("dia", "N/A"), inline=True)
                embed_log.add_field(name="👮 Apagado por", value=f"{interaction.user.mention} (`{interaction.user.display_name}`)", inline=True)
                embed_log.add_field(name="💬 Motivo", value=self.reason.value, inline=False)
                embed_log.set_footer(text=f"ID do Relatório: {rel_id_to_delete} | {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}")
                await log_channel.send(embed=embed_log)

            await interaction.followup.send(f"✅ Relatório apagado com sucesso e log enviado para o canal de registros.", ephemeral=True)
            
            # Atualiza a view principal após a exclusão para refletir a mudança
            self.parent_view.all_relatorios_data = carregar_json(RELATORIOS_FILE)
            self.parent_view.selected_relatorio_id = None
            self.parent_view.state = "militar_options" # Volta para as opções do militar ou initial se ele não tiver mais relatórios
            self.parent_view.current_page = 0
            self.parent_view.update_view()
            
            embed_updated = await self.parent_view.generate_embed()
            await self.parent_view.message.edit(embed=embed_updated, view=self.parent_view)

        else:
            await interaction.followup.send("❌ Relatório não encontrado para exclusão.", ephemeral=True)


