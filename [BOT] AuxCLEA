@bot.command()
async def agendar_aula(ctx, turma: str, responsavel: str, auxiliares: str, tipo: str, horario: str, *, codigo: str):
    turma = turma.strip("Tt")
    if turma not in TURMAS:
        return await ctx.reply(embed=discord.Embed(description=f"❌ Turma inválida. Disponíveis: {', '.join(TURMAS.keys())}", color=0xE74C3C))

    canal_id = TURMAS[turma]["canal_id"]
    mencao_id = TURMAS[turma]["mencao_id"]
    canal = ctx.guild.get_channel(canal_id)
    mencao = f"<@&{mencao_id}>"

    if not canal:
        return await ctx.reply(embed=discord.Embed(description="❌ Canal da turma não encontrado. Verifique se o ID está correto ou se o bot tem permissão.", color=0xE74C3C))

    if codigo.lower().strip() == "discord":
        link = f"https://discord.com/channels/{ctx.guild.id}/{canal.id}"
        canal_info = f"[🔗 Acesse a aula]({link})"
    else:
        canal_info = codigo

    embed = discord.Embed(
        title="📚 | ANÚNCIO DE AULA!",
        description=(
            f"**Horário:**\n**{horario}**\n"
            f"**Instrutor(es):**\n**{responsavel}**\n"
            f"**Auxiliar(es):**\n**{auxiliares}**\n"
            f"**Tipo de aula:**\n**{tipo}**\n"
            f"**Código/Canal:**\n{canal_info}\n"
            f"**Menção:**\n{mencao}"
        ),
        color=0x2ECC71
    )
    embed.set_footer(text=f"Aula agendada por {ctx.author.display_name}")
    await canal.send(content=mencao, embed=embed)
    await ctx.reply(embed=discord.Embed(description="✅ Aula agendada com sucesso!", color=0x2ECC71))

@bot.command()
async def agendar_tarefa(ctx, turma: str, responsavel: str, *, dados: str):
    turma = turma.strip("Tt")
    if turma not in TURMAS:
        return await ctx.reply(embed=discord.Embed(description=f"❌ Turma inválida. Disponíveis: {', '.join(TURMAS.keys())}", color=0xE74C3C))

    partes = [p.strip() for p in dados.split("|")]
    if len(partes) < 3:
        return await ctx.reply(embed=discord.Embed(description="❌ Formato inválido. Use: Tarefa | Início | Fim", color=0xE74C3C))

    tarefa, inicio, fim = partes[0], partes[1], partes[2]

    canal_id = TURMAS[turma]["canal_id"]
    mencao_id = TURMAS[turma]["mencao_id"]
    canal_final = ctx.guild.get_channel(canal_id)
    canal_autorizar = ctx.guild.get_channel(CANAL_REVISAO_TAREFA)
    mencao = f"<@&{mencao_id}>"
    data = datetime.utcnow().strftime("%d/%m/%Y")

    embed_tarefa = discord.Embed(
        title="📘 | Tarefa da Turma!",
        description=(
            f"**Instrutor Responsável:**\n**{responsavel}**\n"
            f"**Tarefa:**\n**{tarefa}**\n"
            f"**Início do prazo:**\n**{inicio}**\n"
            f"**Fim do prazo:**\n**{fim}**\n"
            f"**Menção:**\n{mencao}\n"
            f"**Data:**\n{data}"
        ),
        color=0x3498DB
    )
    embed_tarefa.set_footer(text=f"Enviado por {ctx.author.display_name}")

    if any(role.id in AUTORIZADOS_TAREFA for role in ctx.author.roles):
        await canal_final.send(content=mencao, embed=embed_tarefa)
        await ctx.reply(embed=discord.Embed(description="✅ Tarefa enviada com sucesso!", color=0x2ECC71))
    elif has_clea_role(ctx.author):
        view_autorizacao = AutorizacaoTarefa(canal_final, mencao, embed_tarefa)
        await canal_autorizar.send(embed=embed_tarefa, view=view_autorizacao)
        await ctx.reply(embed=discord.Embed(description="📨 Enviado para autorização do CLEA.", color=0xF1C40F))
    else:
        await ctx.reply(embed=discord.Embed(description="❌ Você não possui permissão para enviar tarefas.", color=0xE74C3C))

