# ===================== VIEW INTERATIVA =====================
class ErroRemocaoView(View):
    def __init__(self, ctx, membro, erros, pagina=0):
        super().__init__(timeout=60)
        self.ctx = ctx
        self.membro = membro
        self.erros = erros
        self.pagina = pagina
        self.itens_por_pagina = 5
        self.max_paginas = math.ceil(len(erros) / self.itens_por_pagina)
        self.atualizar_botoes()

    def atualizar_botoes(self):
        self.clear_items()
        inicio = self.pagina * self.itens_por_pagina
        fim = inicio + self.itens_por_pagina

        for i, erro in enumerate(self.erros[inicio:fim], start=inicio):
            botao = Button(label=f"Remover: {erro['erro'][:50]}", style=discord.ButtonStyle.red)
            botao.callback = self.gerar_callback(i)
            self.add_item(botao)

        if self.max_paginas > 1:
            if self.pagina > 0:
                voltar = Button(label="⬅️ Anterior", style=discord.ButtonStyle.gray)
                voltar.callback = self.voltar
                self.add_item(voltar)

            if self.pagina < self.max_paginas - 1:
                proxima = Button(label="➡️ Próxima", style=discord.ButtonStyle.gray)
                proxima.callback = self.proxima
                self.add_item(proxima)

    def gerar_callback(self, index):
        async def callback(interaction):
            if interaction.user != self.ctx.author:
                return await interaction.response.send_message("❌ Apenas quem usou o comando pode interagir.", ephemeral=True)

            erro_removido = self.erros.pop(index)
            if self.erros:
                salvar_json("erros_gramaticais.json", {str(self.membro.id): self.erros})
            else:
                dados = carregar_json("erros_gramaticais.json")
                dados.pop(str(self.membro.id), None)
                salvar_json("erros_gramaticais.json", dados)

            await interaction.response.send_message(f"🧹 Erro removido: `{erro_removido['erro']}`", ephemeral=True)

            if not self.erros:
                await interaction.message.edit(content=f"✅ Todos os erros de {self.membro.mention} foram removidos.", embed=None, view=None)
                return

            self.pagina = 0
            self.atualizar_botoes()
            embed = gerar_embed_erros(self.membro, self.erros, self.pagina, self.itens_por_pagina)
            await interaction.message.edit(embed=embed, view=self)

        return callback

    async def voltar(self, interaction):
        self.pagina -= 1
        self.atualizar_botoes()
        embed = gerar_embed_erros(self.membro, self.erros, self.pagina, self.itens_por_pagina)
        await interaction.response.edit_message(embed=embed, view=self)

    async def proxima(self, interaction):
        self.pagina += 1
        self.atualizar_botoes()
        embed = gerar_embed_erros(self.membro, self.erros, self.pagina, self.itens_por_pagina)
        await interaction.response.edit_message(embed=embed, view=self)

# ===================== EMBED DE ERROS =====================
def gerar_embed_erros(membro, erros, pagina, por_pagina):
    inicio = pagina * por_pagina
    fim = inicio + por_pagina
    embed = discord.Embed(
        title=f"✏️ Erros registrados por {membro.display_name}",
        color=discord.Color.red()
    )
    for i, erro in enumerate(erros[inicio:fim], start=inicio + 1):
        embed.add_field(name=f"Erro {i}", value=erro['erro'], inline=False)
    embed.set_footer(text=f"Página {pagina + 1}")
    return embed
    
