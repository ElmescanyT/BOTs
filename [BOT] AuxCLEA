def get_militares_ordenados_por_relatorios(militares_relatorios):
    return sorted(
        [(mid, len(rels)) for mid, rels in militares_relatorios.items()],
        key=lambda x: x[1],
        reverse=True
    )

def get_relatorios_of_militar(self):
    if not self.selected_militar_id:
        return []
        
        relatorios_do_militar = []
        for rel_id, rel_info in self.all_relatorios_data.items():
            if rel_info.get("militar_id") == self.selected_militar_id:
                relatorios_do_militar.append((rel_id, rel_info))
        
        # Ordena os relatórios por data, do mais recente para o mais antigo
        try:
            relatorios_do_militar.sort(key=lambda x: datetime.strptime(x[1].get("dia", "01/01/2000"), "%d/%m/%Y"), reverse=True)
        except ValueError:
            pass # Ignora se a data estiver em formato incorreto

        return relatorios_do_militar

