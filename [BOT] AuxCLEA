async def marcar_presenca(ctx, instrutor: discord.Member, data: str, hora: str, turma: discord.Role, aula: str, *nomes_recebidos):
    canal_id = 1352083498999087124
    canal = bot.get_channel(canal_id)

    presentes = []
    faltantes_justificados = []
    faltantes_atrasados = []

    # Processar lista digitada
    nomes_informados_simples = []

    for nome in nomes_recebidos:
        if nome.endswith("-Justificada"):
            nome_limpo = nome.replace("-Justificada", "").strip()
            faltantes_justificados.append(nome_limpo)
            nomes_informados_simples.append(nome_limpo)
        elif nome.endswith("-Atrasado"):
            nome_limpo = nome.replace("-Atrasado", "").strip()
            faltantes_atrasados.append(nome_limpo)
            nomes_informados_simples.append(nome_limpo)
        else:
            presentes.append(nome.strip())
            nomes_informados_simples.append(nome.strip())

    # Coletar membros da turma
    membros_turma = [m for m in ctx.guild.members if turma in m.roles]
    nomes_membros_turma = []

    for m in membros_turma:
        nomes_membros_turma.append(m.nick if m.nick else m.name)

    # Gerar lista automática de faltantes
    faltantes_automáticos = []
    for nome_turma in nomes_membros_turma:
        if not any(nome_turma.lower() in nome.lower() for nome in nomes_informados_simples):
            faltantes_automáticos.append(nome_turma)

    total_presentes = len(presentes)
    total_faltantes = len(faltantes_justificados) + len(faltantes_atrasados) + len(faltantes_automáticos)

    # Montar conteúdo do embed em formato fixo
