# --- Funções Auxiliares de Permissão ---
def has_clea_role(member):
    return any(role.id == CLEA_ROLE_ID for role in member.roles)

def has_solicitante_role(member):
    return any(role.id == SOLICITANTE_ROLE_ID for role in member.roles)

def has_dev_permission(member):
    return any(role.id in CARGOS_AUTORIZADOS_DEV for role in member.roles)

def has_clea_gestao_permission(member):
    return any(role.id in CARGOS_AUTORIZADOS_CLEA_GESTAO for role in member.roles)

# --- Funções para Manipulação de Dados (JSON) ---
def carregar_json(filepath):
    try:
        with open(filepath, "r", encoding="utf-8") as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}

def salvar_json(filepath, data):
    with open(filepath, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2) # ensure_ascii=False para acentos

def salvar_vinculo(discord_id, roblox_id):
    data = carregar_json(VINCULOS_FILE)
    data[str(discord_id)] = roblox_id
    salvar_json(VINCULOS_FILE, data)

def registrar_ppf_autorizacao(user_id):
    data = carregar_json(PPF_AUTORIZACOES_FILE)
    data[str(user_id)] = data.get(str(user_id), 0) + 1
    salvar_json(PPF_AUTORIZACOES_FILE, data)

# --- Funções de Requisição Roblox API ---
async def get_roblox_data(username):
    async with aiohttp.ClientSession() as session:
        async with session.post(
            "https://users.roblox.com/v1/usernames/users",
            json={"usernames": [username]}
        ) as r:
            data = await r.json()
            if data.get("data") and len(data["data"]) > 0:
                return data["data"][0]
            return None

async def get_user_data(roblox_id):
    async with aiohttp.ClientSession() as session:
        async with session.get(f"https://users.roblox.com/v1/users/{roblox_id}") as r:
            if r.status != 200:
                return None
            return await r.json()

async def get_group_rank(user_id, group_id):
    async with aiohttp.ClientSession() as session:
        async with session.get(f"https://groups.roblox.com/v1/users/{user_id}/groups") as r:
            if r.status != 200:
                print(f"[ERRO] Status {r.status} ao buscar grupos de {user_id}")
                return None
            data = await r.json()

            if 'data' not in data:
                return None

            for group_info in data['data']:
                group = group_info.get("group")
                role = group_info.get("role")
                if group and role and group.get("id") == group_id:
                    return role.get("name") # Retorna o nome do cargo
            return None

# --- Views Interativas ---
class PPFView(View):
    def __init__(self, autor_msg):
        super().__init__(timeout=None)
        self.autor_msg = autor_msg
        self.acao_realizada = False

    def disable_all(self):
        for item in self.children:
            item.disabled = True

    @discord.ui.button(label="✅ Autorizar", style=discord.ButtonStyle.success)
    async def aceitar(self, interaction: discord.Interaction, button: Button):
        if self.acao_realizada:
            return await interaction.response.send_message("❗ Esta solicitação já foi respondida.", ephemeral=True)
        if not has_clea_role(interaction.user):
            return await interaction.response.send_message("⛔ Você não tem permissão para isso.", ephemeral=True)

        # Registrar a autorização
        registrar_ppf_autorizacao(interaction.user.id)

        frase = random.choice(autorizado_frases).format(superior=interaction.user.mention)
        embed = discord.Embed(description=f"{self.autor_msg.mention}, {frase}", color=0x2ECC71)
        await interaction.channel.send(embed=embed)

        button.label = f"✅ Autorizado por {interaction.user.display_name}"
        self.disable_all()
        self.acao_realizada = True
        await interaction.message.edit(view=self)
        await interaction.response.defer()

    @discord.ui.button(label="❌ Negar", style=discord.ButtonStyle.danger)
    async def negar(self, interaction: discord.Interaction, button: Button):
        if self.acao_realizada:
            return await interaction.response.send_message("❗ Esta solicitação já foi respondida.", ephemeral=True)
        if not has_clea_role(interaction.user):
            return await interaction.response.send_message("⛔ Você não tem permissão para isso.", ephemeral=True)

        frase = random.choice(negado_frases).format(superior=interaction.user.mention)
        embed = discord.Embed(
            title="❌ Permissão Negada",
            description=f"{self.autor_msg.mention}, {frase}",
            color=0xE74C3C
        )
        button.label = f"❌ Negado por {interaction.user.display_name}"
        self.disable_all()
        self.acao_realizada = True
        await interaction.message.edit(view=self)
        await interaction.response.send_message(embed=embed)

