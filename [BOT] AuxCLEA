@bot.command(name="confirmar_relatorio")
async def confirmar_relatorio(ctx, militar: discord.Member, instrutor: discord.Member, *, dia: str):
    """
    Confirma um relatório de desempenho para um militar, registrando-o e enviando para o canal de logs.
    Este comando só pode ser usado por membros com cargos de gestão.
    """
    if not any(role.id in CARGOS_GESTAO for role in ctx.author.roles):
        return await ctx.send("❌ Você não tem permissão para confirmar relatórios.")

    canal_logs = bot.get_channel(1394419957487632474)
    if canal_logs is None:
        return await ctx.send("❌ Canal de logs não encontrado. Por favor, configure `CANAL_LOGS_EXCLUSAO_RELATORIOS` corretamente.")

    embed = discord.Embed(
        title="📄 Relatório Confirmado",
        description=(
            f"O relatório de **{militar.mention}** referente à instrução ou auxílio prestado por **{instrutor.mention}** "
            f"no dia **{dia}** foi autorizado por {ctx.author.mention}."
