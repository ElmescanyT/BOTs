@bot.command(name="desempenho_adm")
async def desempenho_adm_command(ctx):
    """
    Exibe o desempenho dos administradores na autorização de relatórios,
    ordenado pela quantidade de relatórios confirmados por cada um.
    Apenas membros com cargos de gestão podem usar este comando.
    """
    if not any(role.id in CARGOS_GESTAO for role in ctx.author.roles):
