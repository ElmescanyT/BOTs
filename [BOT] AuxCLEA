@bot.command(name="desempenho_eqp")
async def desempenho_eqp_command(ctx):
    """
    Exibe o desempenho da equipe (militares) com base nos relatórios que tiveram
    confirmados e nas autorizações de PPF que receberam.
    Apenas membros com cargos de gestão podem usar este comando.
    """
    if not any(role.id in CARGOS_GESTAO for role in ctx.author.roles):
        return await ctx.send("❌ Você não tem permissão para usar este comando. Apenas Supervisão, Coordenação e Diretoria podem ver este desempenho.", ephemeral=True)

    relatorios_data = carregar_json(RELATORIOS_FILE)
    ppf_solicitantes_data = carregar_json(PPF_SOLICITANTES_ACEITOS_FILE)

    desempenho_militares = {}

    # Contabilizar relatórios confirmados
    for relatorio_id, relatorio_info in relatorios_data.items():
        militar_id = relatorio_info.get("militar_id")
        if militar_id:
            if militar_id not in desempenho_militares:
                desempenho_militares[militar_id] = {"relatorios": 0, "ppfs": 0}
            desempenho_militares[militar_id]["relatorios"] += 1

    # Contabilizar PPFs aceitos (apenas para quem solicitou e teve aceito)
    for solicitante_id, count in ppf_solicitantes_data.items():
        if solicitante_id not in desempenho_militares:
            desempenho_militares[solicitante_id] = {"relatorios": 0, "ppfs": 0}
        desempenho_militares[solicitante_id]["ppfs"] = count

    if not desempenho_militares:
        return await ctx.send(embed=discord.Embed(
            description="⚠️ Nenhum dado de desempenho (relatórios ou PPFs) encontrado para a equipe ainda.",
            color=0xF1C40F
        ))
    
    members_cache = {str(m.id): m for m in ctx.guild.members}
    view = DesempenhoEqpView(desempenho_militares, members_cache=members_cache)
    embed = await view.generate_embed()
    view.message = await ctx.send(embed=embed, view=view)

