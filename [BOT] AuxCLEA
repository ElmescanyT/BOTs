def hora_para_minutos(hora_str):
    try:
        h, m = map(int, hora_str.split(":"))
        return h * 60 + m
    except:
        return None

def dentro_do_intervalo(hora_atual, inicio, fim):
    if inicio is None or fim is None:
        return False
    if fim < inicio:  # intervalo que atravessa a meia-noite
        return hora_atual >= inicio or hora_atual <= fim
    return inicio <= hora_atual <= fim

@bot.event
async def on_message(message):
    if message.author.bot:
        return

    if message.author.id == DONO_ID:
        conteudo = message.content.lower()

        if "quais membros estão disponíveis" in conteudo:
            try:
                # === Determinar hora ===
                hora_atual = None
                hora_exibicao = None
                if "são" in conteudo:
                    try:
                        partes = message.content.lower().split("são")
                        hora_str = partes[1].split(",")[0].strip()
                        hora_atual = hora_para_minutos(hora_str)
                        hora_exibicao = hora_str
                    except:
                        hora_atual = None

                if hora_atual is None:  # usa hora atual se não especificar
                    agora = datetime.utcnow()
                    hora_atual = agora.hour * 60 + agora.minute
                    hora_exibicao = agora.strftime("%H:%M")

                # === Buscar relatórios no canal ===
                canal = bot.get_channel(CANAL_HORARIOS_ID)
                mensagens = [msg async for msg in canal.history(limit=50)]

                disponiveis = []

                hoje = datetime.utcnow().strftime("%A").lower()
                dias_semana = {
                    "monday": "segunda-feira",
                    "tuesday": "terça-feira",
                    "wednesday": "quarta-feira",
                    "thursday": "quinta-feira",
                    "friday": "sexta-feira",
                    "saturday": "sábado",
                    "sunday": "domingo",
                }
                dia_em_portugues = dias_semana[hoje]

                for msg in mensagens:
                    texto = msg.content

                    if texto.startswith("**Relatório de disponibilidade!**"):
                        linhas = texto.split("\n")

                        nome_linha = linhas[1].replace("**Nome:", "").replace("**", "").strip()
                        nome_membro = nome_linha

                        for linha in linhas:
                            # Remove formatação de markdown (** __ etc.)
                            linha_limpa = linha.replace("*", "").replace("_", "").lower()

                            if dia_em_portugues in linha_limpa:
                                # Captura todos os intervalos tipo "08:00 até 11:00"
                                intervalos = re.findall(r"(\d{2}:\d{2})\s*até\s*(\d{2}:\d{2})", linha_limpa)

                                for inicio_str, fim_str in intervalos:
                                    inicio = hora_para_minutos(inicio_str)
                                    fim = hora_para_minutos(fim_str)

                                    if dentro_do_intervalo(hora_atual, inicio, fim):
                                        disponiveis.append(nome_membro)

                # === Embed formal ===
                embed = discord.Embed(
                    title="📋 Relatório de Disponibilidade",
                    description=f"**Horário consultado:** {hora_exibicao} UTC\n**Dia da semana:** {dia_em_portugues.capitalize()}",
                    color=discord.Color.dark_green()
                )

                if disponiveis:
                    membros_lista = "\n".join(disponiveis)
                    embed.add_field(name=f"Membros disponíveis ({len(disponiveis)})", value=membros_lista, inline=False)
                else:
                    embed.add_field(name="Membros disponíveis", value="Nenhum membro disponível no momento.", inline=False)

                embed.set_footer(text="Sistema Automático • CLEA")

                await message.channel.send(embed=embed)

            except Exception as e:
                await message.channel.send(f"⚠️ Erro inesperado: {e}")

    await bot.process_commands(message)
    
