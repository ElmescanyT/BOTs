        f"> ```Comparecimentos | {turma.name} | {aula}```\n"
        "**> Presentes:\n"
        "> - Lista de presença.\n"
    )

    for p in presentes:
        conteudo += f"> \n> - {p}\n"

    conteudo += f"> \n> - Número de presentes no total: {total_presentes} <:CLEA:1333973615091384361>**\n"

    if total_faltantes > 0:
        conteudo += f"\n**> Faltantes: {total_faltantes}\n"
        for f in faltantes_justificados:
            conteudo += f"> \n> - {f} (Justificada)\n"
        for f in faltantes_atrasados:
            conteudo += f"> \n> - {f} (Atrasado)\n"
        for f in faltantes_automáticos:
            conteudo += f"> \n> - {f}\n"
        conteudo += "**\n"

    conteudo += f"\n**Instrutor:** {instrutor.mention}"

    await canal.send(content=conteudo)
