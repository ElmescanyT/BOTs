@bot.event
async def on_message(message):
    if message.author.bot:
        return

    if message.content.strip().upper() == "PPF!":
        if has_clea_role(message.author):
            embed = discord.Embed(
                title="📛 Confusão Hierárquica Detectada",
                description=f"{message.author.mention}, você é quem **autoriza** a permissão.\nSolicitar PPF sendo do CLEA é como o General pedir permissão ao soldado. Volte ao seu posto.",
                color=0xF1C40F
            )
            embed.set_footer(text="Sistema de PPF • CLEA")
            return await message.channel.send(embed=embed)

        if has_solicitante_role(message.author):
            view = PPFView(message.author)
            embed = discord.Embed(
                title="📢 Solicitação de PPF Detectada",
                description="Clique em ✅ para **autorizar** ou ❌ para **negar** a permissão.",
                color=0x3498DB
            )
            embed.set_footer(text="Somente membros do CLEA podem reagir.")
            return await message.channel.send(embed=embed, view=view)

    await bot.process_commands(message)

