    embed.add_field(
        name="🕒 Data",
        value=f"<t:{int(datetime.now().timestamp())}:F>",
        inline=False
    )

    embed.set_image(url=comprovante.url)

    embed.set_footer(
        text=f"ID do Cliente: {cliente.id}"
