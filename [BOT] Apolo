            embed=embed,
            ephemeral=True
        )

    canal = bot.get_channel(CANAL_PAGAMENTOS)

    embed = discord.Embed(
        title="💰 Novo Pagamento Registrado",
        color=discord.Color.gold(),
        timestamp=datetime.now(GMT_MINUS_3)
    )

    embed.add_field(
        name="👤 Cliente",
        value=cliente.mention,
        inline=False
