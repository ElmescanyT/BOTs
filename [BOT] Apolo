@bot.tree.command(
    name="cadastrar_servico",
    description="Cadastra um novo serviço."
)
@app_commands.describe(
    usuario="Cliente",
    pacote="Pacote adquirido",
    comandos="Comandos/sistemas solicitados",
    link_servidor="Link do servidor",
    prazo_entrega="Prazo de entrega",
    descricao="Descrição do projeto"
)
async def cadastrar_servico(
    interaction: discord.Interaction,
    usuario: discord.Member,
    pacote: str,
    comandos: str,
    link_servidor: str,
    prazo_entrega: str,
    descricao: str
):

    if not possui_permissao(interaction.user):
        embed = discord.Embed(
            title="❌ Sem Permissão",
            description="Você não possui permissão para utilizar este comando.",
            color=discord.Color.red()
        )

        return await interaction.response.send_message(
            embed=embed,
            ephemeral=True
        )

    canal = bot.get_channel(CANAL_SERVICOS)

    if canal is None:
        return await interaction.response.send_message(
            "❌ Canal de serviços não encontrado.",
            ephemeral=True
        )

    embed = discord.Embed(
        title="📋 Novo Serviço",
        color=discord.Color.blurple(),
        timestamp=datetime.now(GMT_MINUS_3)
    )

    embed.add_field(
        name="👤 Cliente",
        value=usuario.mention,
        inline=False
    )

    embed.add_field(
        name="📦 Pacote",
        value=pacote,
        inline=True
    )

    embed.add_field(
        name="📅 Prazo de Entrega",
        value=prazo_entrega,
        inline=True
    )

    embed.add_field(
        name="⚙️ Comandos",
        value=comandos,
        inline=False
    )

    embed.add_field(
        name="🔗 Link do Servidor",
        value=link_servidor,
        inline=False
    )

    embed.add_field(
        name="📝 Descrição",
        value=descricao,
        inline=False
    )

    embed.add_field(
        name="👮 Responsável",
        value=interaction.user.mention,
        inline=False
    )

    embed.add_field(
        name="📌 Status",
        value="⏳ Aguardando aprovação",
        inline=False
    )

    embed.set_footer(
        text=f"Cadastro realizado por {interaction.user}"
    )

    await canal.send(
        embed=embed,
        view=ServicoView()
    )

    confirm = discord.Embed(
        title="✅ Serviço cadastrado",
        description="O serviço foi enviado para análise com sucesso.",
        color=discord.Color.green()
    )

    await interaction.response.send_message(
        embed=confirm,
        ephemeral=True
    )

