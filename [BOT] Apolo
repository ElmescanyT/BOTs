def possui_permissao(member: discord.Member):
    return any(cargo.id in CARGO_PERMITIDO for cargo in member.roles)


@bot.event
async def on_ready():

    await bot.change_presence(
        status=discord.Status.dnd,
        activity=discord.Game("Sistema Apollo")
    )

    # Mantém os botões funcionando após reiniciar o bot
    bot.add_view(ServicoView())

    try:
        synced = await bot.tree.sync()
        print(f"{len(synced)} comandos sincronizados.")
    except Exception as e:
        print(e)

    print(f"Logado como {bot.user}")


