@bot.tree.command(
    name="informar",
    description="Envia uma informação em embed."
)
@app_commands.describe(
    canal="Canal onde será enviada a mensagem",
    mensagem="Mensagem a ser enviada"
)
async def informar(
    interaction: discord.Interaction,
    canal: discord.TextChannel,
    mensagem: str
):
    if not possui_permissao(interaction.user):
        embed = discord.Embed(
            title="❌ Sem Permissão",
            description="Você não possui permissão para utilizar este comando.",
            color=discord.Color.red()
        )
        return await interaction.response.send_message(
            embed=embed,
            ephemeral=True
        )

    embed = discord.Embed(
        title="📢 Informação",
        description=mensagem,
        color=discord.Color.blue(),
        timestamp=datetime.utcnow()
    )

    embed.set_footer(
        text=f"Enviado por {interaction.user}"
    )

    await canal.send(embed=embed)

    confirm = discord.Embed(
        title="✅ Sucesso",
        description=f"Informação enviada em {canal.mention}.",
        color=discord.Color.green()
    )

    await interaction.response.send_message(
        embed=confirm,
        ephemeral=True
    )

@bot.tree.command(
    name="cadastrar_cliente",
    description="Cadastra um cliente."
)
@app_commands.describe(
    cliente="Cliente",
    item_id="ID do serviço adquirido",
    data="Data da compra"
)
async def cadastrar_cliente(
    interaction: discord.Interaction,
    cliente: discord.Member,
    item_id: int,
    data: str
):
    if not possui_permissao(interaction.user):
        embed = discord.Embed(
            title="❌ Sem Permissão",
            description="Você não possui permissão para utilizar este comando.",
            color=discord.Color.red()
        )
        return await interaction.response.send_message(
            embed=embed,
            ephemeral=True
        )

    if item_id not in SERVICOS:
        return await interaction.response.send_message(
            "❌ ID de serviço inválido. Use `/consultar_servicos`.",
            ephemeral=True
        )

    servico, valor = SERVICOS[item_id]

    canal = bot.get_channel(CANAL_CADASTROS)

    embed = discord.Embed(
        title="📝 Novo Cadastro",
        color=discord.Color.green(),
        timestamp=datetime.now(GMT_MINUS_3)
    )

    embed.add_field(
        name="👤 Cliente",
        value=cliente.mention,
        inline=False
    )

    embed.add_field(
        name="🆔 ID do Sistema",
        value=f"`{item_id:02d}`",
        inline=True
    )

    embed.add_field(
        name="📦 Serviço",
        value=servico,
        inline=True
    )

    embed.add_field(
        name="💰 Valor",
        value=valor,
        inline=True
    )

    embed.add_field(
        name="📅 Data",
        value=data,
        inline=False
    )

    embed.add_field(
        name="👮 Responsável",
        value=interaction.user.mention,
        inline=False
    )

    if canal:
        await canal.send(embed=embed)

    CARGO_CLIENTE = 1519484107049013338

    cargo = interaction.guild.get_role(CARGO_CLIENTE)

    if cargo:
        try:
            await cliente.add_roles(
                cargo,
                reason=f"Cliente cadastrado por {interaction.user}"
            )
        except discord.Forbidden:
            print("Sem permissão para adicionar o cargo.")
        except discord.HTTPException as e:
            print(f"Erro ao adicionar cargo: {e}")

    confirm = discord.Embed(
        title="✅ Cadastro Realizado",
        description=f"{cliente.mention} foi cadastrado com sucesso.",
        color=discord.Color.green()
    )

    await interaction.response.send_message(
        embed=confirm,
        ephemeral=True
    )


