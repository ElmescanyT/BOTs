class ServicoView(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=None)

    @discord.ui.button(label="Recusar", style=discord.ButtonStyle.danger, emoji="❌", custom_id="servico_recusar")
    async def recusar(self, interaction: discord.Interaction, button: discord.ui.Button):
        canal = interaction.guild.get_channel(CANAL_AVISOS)
        cargo = interaction.guild.get_role(CARGO_EQUIPE)

        aviso = discord.Embed(
            title="❌ Serviço Recusado",
            description=(
                "O Diretor de Programação recusou a solicitação.\n\n"
                f"Entre em contato com o Diretor em <#{CANAL_DIRETOR}> "
                "para verificar o motivo e posteriormente comunicar o cliente."
            ),
            color=discord.Color.red(),
            timestamp=datetime.now(GMT_MINUS_3)
        )
        aviso.set_author(name="Administrador Chefe de Programação • Apolo")
        aviso.add_field(name="Status", value="❌ Cancelado", inline=True)
        aviso.set_footer(text="AetherScany • Gerenciamento de Serviços")

        if canal:
            await canal.send(content=cargo.mention, embed=aviso)

        embed = interaction.message.embeds[0]
        embed.color = discord.Color.red()
        embed.add_field(name="📌 Status", value="❌ Serviço Recusado", inline=False)

        for item in self.children:
            item.disabled = True

        await interaction.message.edit(embed=embed, view=self)
        await interaction.response.send_message("Serviço recusado.", ephemeral=True)

    @discord.ui.button(label="Aceitar", style=discord.ButtonStyle.success, emoji="✅", custom_id="servico_aceitar")
    async def aceitar(self, interaction: discord.Interaction, button: discord.ui.Button):
        canal = interaction.guild.get_channel(CANAL_AVISOS)
        cargo = interaction.guild.get_role(CARGO_EQUIPE)

        aviso = discord.Embed(
            title="✅ Serviço Aprovado",
            description=(
                "O Diretor de Programação aprovou o serviço.\n\n"
                "Solicitamos orientar o cliente a efetuar o pagamento para início do desenvolvimento."
            ),
            color=discord.Color.green(),
            timestamp=datetime.now(GMT_MINUS_3)
        )
        aviso.set_author(name="Administrador Chefe de Programação • Apolo")
        aviso.add_field(name="Status", value="✅ Aprovado", inline=True)
        aviso.set_footer(text="AetherScany • Gerenciamento de Serviços")

        if canal:
            await canal.send(content=cargo.mention, embed=aviso)

        embed = interaction.message.embeds[0]
        embed.color = discord.Color.green()
        embed.add_field(name="📌 Status", value="✅ Serviço Aceito", inline=False)

        for item in self.children:
            if item.custom_id in ("servico_recusar","servico_aceitar"):
                item.disabled = True

        await interaction.message.edit(embed=embed, view=self)
        await interaction.response.send_message("Serviço aprovado.", ephemeral=True)

    @discord.ui.button(label="Iniciar Projeto", style=discord.ButtonStyle.secondary, emoji="🟡", custom_id="servico_iniciar")
    async def iniciar(self, interaction: discord.Interaction, button: discord.ui.Button):
        embed = interaction.message.embeds[0]
