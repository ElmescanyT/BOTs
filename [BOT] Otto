@bot.command()
async def criar_torneio(
    ctx,
    nome: str,
    canal: discord.TextChannel = None,
    cargo: discord.Role = None,
    *,
    regras: str = "Nenhuma regra especificada"
):
    if not tem_permissao(ctx.author):
        return await ctx.reply(embed=discord.Embed(description="🚫 Sem permissão.", color=0xE74C3C))

    torneios = carregar_json(TORNEIOS_FILE)
    if nome in torneios:
        return await ctx.reply(embed=discord.Embed(description="❌ Torneio já existe.", color=0xE74C3C))

    canal = canal or ctx.channel

    torneios[nome] = {
        "jogadores": [],
        "chaves": [],
        "regras": regras,
        "canal_id": canal.id
    }
    salvar_json(TORNEIOS_FILE, torneios)

    embed = discord.Embed(
        title=f"Torneio criado: {nome}",
        description=f"**Informativos:**\n{regras}\n\n📍 Canal Oficial do Torneio: {canal.mention}",
        color=0xF39C12
    )

    # Mencionar cargo fora do embed, se fornecido
    if cargo:
        await canal.send(content=f"{cargo.mention}")

    await canal.send(embed=embed)
    await ctx.reply(embed=discord.Embed(description="✅ Torneio criado com sucesso!", color=0x2ECC71))

# ===============================================
# Adicionar jogadores com limite
# ===============================================
@bot.command()
async def adicionar_jogador(ctx, nome_torneio: str, *jogadores: discord.Member):
    if not tem_permissao(ctx.author):
        return await ctx.reply(embed=discord.Embed(description="🚫 Sem permissão.", color=0xE74C3C))
    if len(jogadores) == 0 or len(jogadores) > 5:
        return await ctx.reply(embed=discord.Embed(description="⚠️ Você deve adicionar entre 1 e 5 jogadores por vez.", color=0xF1C40F))
    torneios = carregar_json(TORNEIOS_FILE)
    if nome_torneio not in torneios:
        return await ctx.reply(embed=discord.Embed(description="❌ Torneio não encontrado.", color=0xE74C3C))

    adicionados = []
    ja_adicionados = []
    for jogador in jogadores:
        if str(jogador.id) not in torneios[nome_torneio]["jogadores"]:
            torneios[nome_torneio]["jogadores"].append(str(jogador.id))
            adicionados.append(jogador.mention)
        else:
            ja_adicionados.append(jogador.mention)
    salvar_json(TORNEIOS_FILE, torneios)
    embed = discord.Embed(title=f"Jogadores adicionados ao torneio {nome_torneio}:", color=0x2ECC71)
    if adicionados:
        embed.add_field(name="✅ Adicionados", value="\n".join(adicionados), inline=False)
    if ja_adicionados:
        embed.add_field(name="⚠️ Já estavam no torneio", value="\n".join(ja_adicionados), inline=False)
    await ctx.reply(embed=embed)

