@bot.command()
async def ver_jogadores(ctx, nome_torneio: str):
    torneios = carregar_json(TORNEIOS_FILE)
    if nome_torneio not in torneios:
        return await ctx.reply(embed=discord.Embed(description="❌ Torneio não encontrado.", color=0xE74C3C))
    jogadores = torneios[nome_torneio]["jogadores"]
    if not jogadores:
        return await ctx.reply(embed=discord.Embed(description="👥 Nenhum jogador adicionado.", color=0x95A5A6))
    nomes = []
    for j in jogadores:
        try:
            membro = await ctx.guild.fetch_member(int(j))
            nomes.append(membro.display_name)
        except:
            nomes.append(f"Desconhecido ({j})")
    embed = discord.Embed(title=f"🎮 Jogadores do Torneio: {nome_torneio}", description="\n".join(f"- {n}" for n in nomes), color=0x2980B9)
    await ctx.reply(embed=embed)

