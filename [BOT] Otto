@bot.command()
async def deletar_torneio(ctx, nome_torneio: str):
    if not tem_permissao(ctx.author):
        return await ctx.reply(embed=discord.Embed(description="🚫 Sem permissão.", color=0xE74C3C))

    torneios = carregar_json(TORNEIOS_FILE)
    if nome_torneio not in torneios:
        return await ctx.reply(embed=discord.Embed(description="❌ Torneio não encontrado.", color=0xE74C3C))

    class ConfirmarDelete(View):
        def __init__(self):
            super().__init__(timeout=30)
            self.value = None

        @discord.ui.button(label="Confirmar", style=discord.ButtonStyle.danger)
        async def confirmar(self, interaction: discord.Interaction, button: discord.ui.Button):
            self.value = True
            await interaction.response.edit_message(content=f"✅ Torneio **{nome_torneio}** deletado com sucesso!", embed=None, view=None)
            self.stop()

        @discord.ui.button(label="Cancelar", style=discord.ButtonStyle.secondary)
        async def cancelar(self, interaction: discord.Interaction, button: discord.ui.Button):
            self.value = False
            await interaction.response.edit_message(content="❌ Ação cancelada.", embed=None, view=None)
            self.stop()

    view = ConfirmarDelete()
    await ctx.reply(embed=discord.Embed(description=f"⚠️ Deseja realmente deletar o torneio **{nome_torneio}**?", color=0xE67E22), view=view)
    await view.wait()

    if view.value:
        torneios.pop(nome_torneio)
        salvar_json(TORNEIOS_FILE, torneios)
        await enviar_log(f"🗑️ Torneio **{nome_torneio}** deletado por {ctx.author.mention}.")
    else:
        await ctx.reply(embed=discord.Embed(description="❌ Deleção cancelada.", color=0x95A5A6))

