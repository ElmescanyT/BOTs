@bot.command()
async def remover_jogador(ctx, nome_torneio: str, jogador: discord.Member):
    if not tem_permissao(ctx.author):
        return await ctx.reply(embed=discord.Embed(description="🚫 Sem permissão.", color=0xE74C3C))
    torneios = carregar_json(TORNEIOS_FILE)
    if nome_torneio not in torneios:
