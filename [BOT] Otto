# Gerar chave
# ===============================================
@bot.command()
async def gerar_chave(ctx, nome_torneio: str):
    if not tem_permissao(ctx.author):
        return await ctx.reply(embed=discord.Embed(description="🚫 Sem permissão.", color=0xE74C3C))

    torneios = carregar_json(TORNEIOS_FILE)
    if nome_torneio not in torneios:
        return await ctx.reply(embed=discord.Embed(description="❌ Torneio não encontrado.", color=0xE74C3C))

    if "chaves" in torneios[nome_torneio] and any(c.get("ganhador") is None for c in torneios[nome_torneio]["chaves"]):
        class ConfirmView(View):
            def __init__(self):
                super().__init__(timeout=30)
                self.value = None

            @discord.ui.button(label="Confirmar", style=discord.ButtonStyle.success)
            async def confirm(self, interaction: discord.Interaction, button: discord.ui.Button):
                self.value = True
                await interaction.response.edit_message(content="🔄 Novo chaveamento será gerado...", view=None)
                self.stop()

            @discord.ui.button(label="Cancelar", style=discord.ButtonStyle.danger)
            async def cancel(self, interaction: discord.Interaction, button: discord.ui.Button):
                self.value = False
                await interaction.response.edit_message(content="❌ Ação cancelada.", view=None)
                self.stop()

        view = ConfirmView()
        await ctx.reply(embed=discord.Embed(description="⚠️ Já existe um chaveamento em andamento. Deseja substituir?", color=0xF39C12), view=view)
        await view.wait()
        if not view.value:
            return

    jogadores = torneios[nome_torneio]["jogadores"]
    if len(jogadores) < 2:
        return await ctx.reply(embed=discord.Embed(description="❌ É necessário pelo menos 2 jogadores para gerar um chaveamento.", color=0xE74C3C))

    random.shuffle(jogadores)
    chaves = []
    for i in range(0, len(jogadores), 2):
        j1 = jogadores[i]
        j2 = jogadores[i+1] if i+1 < len(jogadores) else None
        chaves.append({"j1": j1, "j2": j2, "ganhador": None})

    torneios[nome_torneio]["chaves"] = chaves
    salvar_json(TORNEIOS_FILE, torneios)

    canal = bot.get_channel(torneios[nome_torneio]["canal_id"])
    embed = discord.Embed(title=f"🎯 Chaveamento Atualizado: {nome_torneio}", description="Confira os confrontos atualizados.", color=0x9B59B6)
    for i, chave in enumerate(chaves):
        j1 = await ctx.guild.fetch_member(int(chave['j1']))
        if chave['j2']:
            j2 = await ctx.guild.fetch_member(int(chave['j2']))
            embed.add_field(name=f"Chave {i+1:02d}", value=f"🎮 {j1.display_name} vs {j2.display_name}", inline=False)
        else:
            embed.add_field(name=f"Chave {i+1:02d}", value=f"🎟️ {j1.display_name} avançou automaticamente.", inline=False)
    await canal.send(embed=embed)

