@bot.command()
async def resultado_chave(ctx, nome_torneio: str, numero: int, ganhador: discord.Member):
    if not tem_permissao(ctx.author):
        return await ctx.reply(embed=discord.Embed(description="🚫 Sem permissão.", color=0xE74C3C))

    torneios = carregar_json(TORNEIOS_FILE)
    if nome_torneio not in torneios:
        return await ctx.reply(embed=discord.Embed(description="❌ Torneio não encontrado.", color=0xE74C3C))

    try:
        chave = torneios[nome_torneio]["chaves"][numero - 1]
        chave["ganhador"] = str(ganhador.id)
        salvar_json(TORNEIOS_FILE, torneios)

        await ctx.reply(embed=discord.Embed(description=f"✅ Resultado registrado. {ganhador.mention} venceu a Chave {numero:02d}!", color=0x2ECC71))

        canal = bot.get_channel(torneios[nome_torneio]["canal_id"])

        # Deleta a última mensagem de chaveamento, se existir
        ultima_msg_id = torneios[nome_torneio].get("ultima_msg_chaveamento")
        if ultima_msg_id:
            try:
                ultima_msg = await canal.fetch_message(ultima_msg_id)
                await ultima_msg.delete()
            except:
                pass  # ignora se não conseguir deletar

        # Cria novo embed com chaveamento atualizado
        embed_chaves = discord.Embed(title=f"📋 Chaveamento Atualizado - {nome_torneio}", color=0x3498DB)
        for i, chave in enumerate(torneios[nome_torneio]["chaves"]):
            j1 = await ctx.guild.fetch_member(int(chave["j1"]))
            j1_nome = j1.display_name
            if chave["j2"]:
                j2 = await ctx.guild.fetch_member(int(chave["j2"]))
                j2_nome = j2.display_name
                resultado = f"{j1_nome} vs {j2_nome}"
            else:
                resultado = f"{j1_nome} passou direto"

            ganhador_id = chave.get("ganhador")
            if ganhador_id:
                ganhador_nome = await ctx.guild.fetch_member(int(ganhador_id))
                resultado += f"\n🏅 Vencedor: {ganhador_nome.display_name}"

            embed_chaves.add_field(name=f"Chave {i+1:02d}", value=resultado, inline=False)

        nova_msg = await canal.send(embed=embed_chaves)
        torneios[nome_torneio]["ultima_msg_chaveamento"] = nova_msg.id
        salvar_json(TORNEIOS_FILE, torneios)

        # Se todos os vencedores foram definidos, inicia nova rodada ou finaliza
        if all(c.get("ganhador") for c in torneios[nome_torneio]["chaves"]):
            vencedores = [c["ganhador"] for c in torneios[nome_torneio]["chaves"]]

            if len(vencedores) == 1:
                vencedor_final = await ctx.guild.fetch_member(int(vencedores[0]))
                embed = discord.Embed(
                    title=f"🏆 CAMPEÃO - {nome_torneio}",
                    description=f"Parabéns {vencedor_final.mention}! Você venceu o torneio 🎉",
                    color=0xFFD700
                )
                await canal.send(embed=embed)
                return

            random.shuffle(vencedores)
            nova_rodada = []
            for i in range(0, len(vencedores), 2):
                j1 = vencedores[i]
                j2 = vencedores[i+1] if i+1 < len(vencedores) else None
                nova_rodada.append({"j1": j1, "j2": j2, "ganhador": None})

            torneios[nome_torneio]["chaves"] = nova_rodada
            salvar_json(TORNEIOS_FILE, torneios)

            embed = discord.Embed(
                title=f"🔁 Nova Rodada - {nome_torneio}",
                description="Iniciando nova rodada com os vencedores anteriores.",
                color=0x1ABC9C
            )
            for i, chave in enumerate(nova_rodada):
                j1 = await ctx.guild.fetch_member(int(chave['j1']))
                if chave['j2']:
                    j2 = await ctx.guild.fetch_member(int(chave['j2']))
                    embed.add_field(name=f"Chave {i+1:02d}", value=f"🎮 {j1.display_name} vs {j2.display_name}", inline=False)
                else:
                    embed.add_field(name=f"Chave {i+1:02d}", value=f"🎟️ {j1.display_name} passou direto para próxima rodada", inline=False)
            await canal.send(embed=embed)

    except Exception as e:
        return await ctx.reply(embed=discord.Embed(description=f"❌ Erro ao registrar resultado: {e}", color=0xE74C3C))

