@bot.command()
async def mute(ctx, membro: discord.Member, codigo: int):
    # Verifica se o autor tem um dos cargos autorizados
    if not any(role.id in IDS_AUTORIZADOS for role in ctx.author.roles):
        return await ctx.reply(embed=discord.Embed(
            description="🚫 Você não tem permissão para usar este comando.",
            color=0xE74C3C
        ))

    if codigo not in codigos_mute:
        return await ctx.reply(embed=discord.Embed(
            description="❌ Código de mute inválido.",
            color=0xE67E22
        ))

    motivo, tempo_str = codigos_mute[codigo]

    # Converte o tempo para timedelta
    if "hora" in tempo_str:
        duracao = timedelta(hours=int(tempo_str.split()[0]))
    elif "dia" in tempo_str:
        duracao = timedelta(days=int(tempo_str.split()[0]))
    elif "semana" in tempo_str:
        duracao = timedelta(weeks=int(tempo_str.split()[0]))
    elif "minuto" in tempo_str:
        duracao = timedelta(minutes=int(tempo_str.split()[0]))
    else:
        return await ctx.reply("⛔ Erro no tempo do código. Informe o responsável.")

    # Define horário com timezone UTC
    until = datetime.now(timezone.utc) + duracao

    try:
        await membro.timeout(until)
    except Exception as e:
        return await ctx.reply(embed=discord.Embed(
            description=f"❌ Erro ao aplicar mute: `{e}`",
            color=0xE74C3C
        ))

    # Embed de log
    embed = discord.Embed(title="🔇 MUTE APLICADO", color=0x3498DB)
    embed.add_field(name="👤 Membro", value=membro.mention, inline=True)
    embed.add_field(name="🕒 Duração", value=tempo_str, inline=True)
    embed.add_field(name="📋 Motivo", value=motivo, inline=False)
    embed.add_field(name="📄 Código", value=str(codigo), inline=True)
    embed.add_field(name="🪖 Responsável", value=ctx.author.mention, inline=False)
    embed.set_footer(text="Sistema disciplinar automático • Quartel dos Eventos")

    # Feedback no canal onde o comando foi executado
    await ctx.send(
        f"+mute {membro.mention} {tempo_str} {motivo} code: {codigo} Responsável: {ctx.author.mention}"
    )

    # Envia o embed no canal de logs
    canal_logs = bot.get_channel(CANAL_LOGS_ID)
    if canal_logs:
        await canal_logs.send(embed=embed)
        
