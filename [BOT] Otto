def tem_permissao(usuario):
    return any(role.id in CARGOS_AUTORIZADOS for role in getattr(usuario, 'roles', []))

def carregar_json(caminho):
    try:
        with open(caminho, "r") as f:
            return json.load(f)
    except:
        if "torneios" in caminho:
            return {}
        return []

def salvar_json(caminho, dados):
    with open(caminho, "w") as f:
        json.dump(dados, f, indent=4)

async def enviar_log(mensagem: str):
    canal_logs = bot.get_channel(CANAL_LOGS_ID)
    if canal_logs:
        await canal_logs.send(mensagem)

