@bot.command()
async def ban(ctx, membro: discord.Member, codigo: int):
    if not any(role.id in IDS_AUTORIZADOS for role in ctx.author.roles):
        return await ctx.reply(embed=discord.Embed(description="🚫 Você não tem permissão para usar este comando.", color=0xE74C3C))

    if codigo not in codigos_ban:
        return await ctx.reply(embed=discord.Embed(description="❌ Código de banimento inválido.", color=0xE67E22))

    motivo = codigos_ban[codigo]

    embed = discord.Embed(title="🚫 BANIMENTO APLICADO", color=0xE74C3C)
    embed.add_field(name="👤 Membro", value=membro.mention, inline=True)
    embed.add_field(name="📋 Motivo", value=motivo, inline=False)
    embed.add_field(name="📄 Código", value=str(codigo), inline=True)
    embed.add_field(name="🪖 Responsável", value=ctx.author.mention, inline=False)
    embed.set_footer(text="Sistema disciplinar automático • Quartel dos Eventos")

    await ctx.send(f"+ban {membro.mention} {motivo} code: {codigo} Responsável: {ctx.author.mention}")

    canal_logs = bot.get_channel(CANAL_LOGS_ID)
    if canal_logs:
        await canal_logs.send(embed=embed)

    try:
        await membro.ban(reason=f"{motivo} - Código {codigo} - Aplicado por {ctx.author}")
    except Exception as e:
        await ctx.reply(embed=discord.Embed(description=f"❌ Erro ao aplicar ban: `{e}`", color=0xE74C3C))

